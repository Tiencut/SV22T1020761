@model ProductSearchInput
@{
    ViewBag.Title = "Lập đơn hàng";
}

<div class="row">
    <!-- Tìm kiếm & chọn mặt hàng -->
    <div class="col-4">
        <div class="card card-outline card-primary h-100">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-search"></i>
                    Lựa chọn hàng cần bán
                </h5>
            </div>

            <div class="card-body">
                <!-- Search -->
                <form id="formSearch" class="md-3"
                      method="get"
                      action="~/Order/SearchProduct"
                      data-target="searchResult"
                      onsubmit="paginationSearch(event, this, 1)">

                    <input type="hidden" asp-for="PageSize" />

                    <div class="input-group">

                        <input class="form-control"
                               asp-for="SearchValue"
                               placeholder="Nhập tên mặt hàng cần tìm" autofocus />

                        <button class="btn btn-primary">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </form>

                <!-- Danh sách mặt hàng -->
                <div id="searchResult"> </div>
            </div>
        </div>
    </div>

    <!-- Giỏ hàng và thông tin khách hàng -->
    <div class="col-8">

        <!-- Giỏ hàng -->
        <div class="row">
            <div class="col-12" id="cart">
            </div>
        </div>

        <!-- Thông tin khách hàng và nơi giao hàng -->
        <div class="row mt-3">
            <div class="col-12">
                <div class="card card-outline card-info">
                    <div class="card-header">
                        <h5 class="mb-0">
                            <i class="bi bi-person"></i>
                            Thông tin khách hàng & nơi giao hàng
                        </h5>
                    </div>

                    <div class="card-body">
                        <form method="post" onsubmit="createOrder(event,this)">
                            <div class="row mb-3">
                                <label class="col-md-2 col-form-label">Khách hàng</label>
                                <div class="col-md-10">
                                    <select class="form-select" name="customerID" asp-items=" await SelectListHelper.Customers()">
                                    </select>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <label class="col-md-2 col-form-label">Tỉnh/thành</label>
                                <div class="col-md-10">
                                    <select class="form-select" name="province" asp-items="await SelectListHelper.Provinces()">
                                    </select>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <label class="col-md-2 col-form-label">Địa chỉ</label>
                                <div class="col-md-10">
                                    <textarea class="form-control" name="address"></textarea>
                                </div>
                            </div>

                            <div class="text-end">
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-check-circle"></i>
                                    Lập đơn hàng
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            paginationSearch(null, document.getElementById("formSearch"), @Model.Page);
            showCart();
        });

        function showCart() {
            // Gọi API bằng fetch
            fetch('/Order/ShowCart')
                .then(response => response.text()) // Chuyển kết quả trả về thành dạng chuỗi (HTML)
                .then(html => {
                    // Đổ trực tiếp chuỗi HTML đó vào trong thẻ có id="cart"
                    document.getElementById("cart").innerHTML = html;
                })
                .catch(error => {
                    console.error("Có lỗi xảy ra khi lấy dữ liệu giỏ hàng:", error);
                });
        }
        function addCartItem(event, form) {
            // 1. Ngăn chặn hành vi submit mặc định của form (giúp trang không bị reload)
            event.preventDefault();

            // 2. Thu thập toàn bộ dữ liệu từ form (các thẻ input, select, textarea có thuộc tính name)
            const formData = new FormData(form);

            // 3. Gửi request POST lên API
            fetch('/Order/AddCartItem', {
                method: 'POST',
                body: formData
            })
            .then(response => response.json()) // Chuyển đổi dữ liệu trả về thành JSON
            .then(data => {
                // 4. Kiểm tra trường code từ JSON trả về
                if (data.code === 0) {
                    // Nếu code = 0 (Thất bại), hiển thị thông báo lỗi
                    alert(data.message);
                    // Lưu ý: Thay vì dùng alert(), bạn cũng có thể gán thông báo này vào một thẻ div lỗi trên màn hình cho đẹp hơn
                } else {
                    // Ngược lại (Thành công), gọi hàm showCart() để load lại giao diện giỏ hàng
                    showCart();
                }
            })
            .catch(error => {
                // Xử lý khi có lỗi mạng hoặc lỗi hệ thống
                console.error("Có lỗi xảy ra khi thêm vào giỏ hàng:", error);
                alert("Hệ thống đang bận, vui lòng thử lại sau!");
            });
        }
        function deleteCartItem(productId) {
            // 1. Gửi request POST đến API kèm tham số productId trên URL
            fetch(`/Order/DeleteCartItem?productId=${productId}`, {
                method: 'POST'
            })
            .then(response => {
                // 2. Kiểm tra xem request có thành công không (HTTP status 200-299)
                if (response.ok) {
                    // Nếu thành công, gọi ngay hàm showCart() để load lại giao diện
                    showCart();
                } else {
                    // Xử lý nếu server báo lỗi (ví dụ: lỗi 404, 500)
                    alert("Có lỗi xảy ra khi xóa sản phẩm khỏi giỏ hàng!");
                }
            })
            .catch(error => {
                // 3. Xử lý khi có lỗi mạng hoặc không kết nối được tới server
                console.error("Lỗi khi xóa sản phẩm:", error);
                alert("Hệ thống đang bận, vui lòng thử lại sau!");
            });
        }
                function clearCart() {
            // 1. Hiển thị hộp thoại xác nhận để tránh khách hàng lỡ tay bấm nhầm
            if (!confirm("Bạn có chắc chắn muốn xóa toàn bộ sản phẩm trong giỏ hàng không?")) {
                return; // Nếu khách chọn Cancel, dừng hàm lại
            }

            // 2. Gửi request POST đến API
            fetch('/Order/ClearCart', {
                method: 'POST'
            })
            .then(response => {
                // 3. Kiểm tra kết quả trả về
                if (response.ok) {
                    // Nếu thành công, load lại giao diện giỏ hàng
                    showCart();
                } else {
                    alert("Có lỗi xảy ra khi xóa giỏ hàng!");
                }
            })
            .catch(error => {
                // Xử lý khi có lỗi mạng
                console.error("Lỗi khi xóa toàn bộ giỏ hàng:", error);
                alert("Hệ thống đang bận, vui lòng thử lại sau!");
            });
        }
        function UpdateCartItem(event, form) {
            // 1. Ngăn chặn trang bị tải lại khi submit form
            event.preventDefault();

            // 2. Đóng gói toàn bộ dữ liệu trong form
            const formData = new FormData(form);

            // 3. Gửi request POST lên API
            fetch('/Order/UpdateCartItem', {
                method: 'POST',
                body: formData
            })
            .then(response => response.json()) // Chuyển kết quả trả về sang JSON
            .then(data => {
                // 4. Kiểm tra mã lỗi trả về
                if (data.code === 0) {
                    // Nếu có lỗi, hiển thị thông báo (có thể lấy data.message từ server trả về)
                    alert(data.message || "Không thể cập nhật giỏ hàng. Vui lòng kiểm tra lại số lượng!");
                } else {
                    // Nếu thành công:

                    // Bước A: Tìm và đóng Modal của Bootstrap 5
                    const modalElement = document.getElementById('dialogModal');
                    if (modalElement) {
                        // Lấy instance (thực thể) của modal hiện tại đang mở
                        const modalInstance = bootstrap.Modal.getInstance(modalElement);
                        if (modalInstance) {
                            modalInstance.hide(); // Lệnh ẩn modal
                        }
                    }

                    // Bước B: Gọi hàm load lại giao diện giỏ hàng
                    showCart();
                }
            })
            .catch(error => {
                // 5. Xử lý khi rớt mạng hoặc server sập
                console.error("Lỗi cập nhật giỏ hàng:", error);
                alert("Hệ thống đang bận, vui lòng thử lại sau!");
            });
        }
                function createOrder(event, form) {
            // 1. Ngăn chặn hành vi submit mặc định để trang không bị load lại
            event.preventDefault();

            // 2. Lấy toàn bộ dữ liệu từ form thanh toán (Tên, SĐT, Địa chỉ, Cách thanh toán...)
            const formData = new FormData(form);

            // 3. Gửi request POST lên API tạo đơn hàng
            fetch('/Order/CreateOrder', {
                method: 'POST',
                body: formData
            })
            .then(response => response.json()) // Chuyển đổi dữ liệu trả về thành dạng JSON
            .then(data => {
                // 4. Kiểm tra mã kết quả
                if (data.code === 0) {
                    // Nếu code = 0 (Thất bại), hiển thị thông báo lỗi từ server
                    alert(data.message || "Có lỗi xảy ra trong quá trình xử lý đơn hàng. Vui lòng kiểm tra lại!");
                } else {
                    // Ngược lại (Thành công), data.code chính là Mã Đơn Hàng (OrderID)
                    // Chuyển hướng trình duyệt sang trang Chi tiết đơn hàng
                    window.location.href = `/Order/Detail/${data.code}`;
                }
            })
            .catch(error => {
                // 5. Xử lý khi rớt mạng hoặc server báo lỗi (500, 404)
                console.error("Lỗi khi tạo đơn hàng:", error);
                alert("Hệ thống đang bận, vui lòng thử lại sau!");
            });
        }
    </script>
}