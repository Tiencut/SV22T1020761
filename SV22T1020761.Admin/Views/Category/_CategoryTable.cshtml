@model SV22T1020761.Models.Common.PagedResult<SV22T1020761.Models.Catalog.Category>

<table class="table table-bordered table-hover mb-0">
    <thead class="table-secondary">
        <tr>
            <th>ID</th>
            <th>Category Name</th>
            <th>Description</th>
            <th class="text-center" style="width:100px;">Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @if (Model?.DataItems != null && Model.DataItems.Count > 0)
        {
            foreach (var category in Model.DataItems)
            {
                <tr>
                    <td>@category.CategoryID</td>
                    <td>@category.CategoryName</td>
                    <td>@category.Description</td>
                    <td class="text-center text-nowrap">
                        <a href="#" class="btn btn-sm btn-primary open-modal" data-url="@Url.Action("Form","Category", new { id = category.CategoryID })">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <a href="#" class="btn btn-sm btn-danger open-modal" data-url="@Url.Action("Form","Category", new { id = category.CategoryID })?delete=true">
                            <i class="bi bi-trash"></i>
                        </a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="4" class="text-center">Không có dữ liệu</td>
            </tr>
        }
    </tbody>
</table>

<ul class="pagination justify-content-center mt-3">
    @if (Model != null && Model.PageCount > 1)
    {
        if (Model.Page > 1)
        {
            <li class="page-item">
                <a class="page-link" href="#" data-page="1">&laquo;</a>
            </li>
        }
        for (int i = Math.Max(1, Model.Page - 2); i <= Math.Min(Model.PageCount, Model.Page + 2); i++)
        {
            <li class="page-item @(i == Model.Page ? "active" : "")">
                <a class="page-link" href="#" data-page="@i">@i</a>
            </li>
        }
        if (Model.Page < Model.PageCount)
        {
            <li class="page-item">
                <a class="page-link" href="#" data-page="@Model.PageCount">&raquo;</a>
            </li>
        }
    }
</ul>