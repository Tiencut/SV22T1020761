@{
    Layout = null;
}
@model SV22T1020761.Models.HR.Employee
<div class="p-3">
    <h5>Bạn có chắc chắn muốn xóa nhân viên <strong>@Model.FullName</strong>?</h5>
    <form id="formEmployeeDelete" method="post" action="~/Employee/DeleteConfirmed">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.EmployeeID" />
        <div class="text-end mt-3">
            <button type="submit" class="btn btn-danger">Xóa</button>
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
        </div>
    </form>
</div>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        var form = document.getElementById('formEmployeeDelete');
        form.addEventListener('submit', async function (e) {
            e.preventDefault();
            var url = form.action;
            var token = form.querySelector('input[name="__RequestVerificationToken"]').value;
            var id = form.querySelector('input[name="id"]').value;
            
            try {
                var res = await fetch(url, {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Content-Type': 'application/x-www-form-urlencoded'
                    },
                    body: '__RequestVerificationToken=' + encodeURIComponent(token) + '&id=' + encodeURIComponent(id)
                });
                if (res.ok) {
                    var html = await res.text();
                    document.getElementById('employeeTableContainer').innerHTML = html;
                    var modalEl = document.getElementById('dialogModal');
                    var modal = bootstrap.Modal.getInstance(modalEl) || new bootstrap.Modal(modalEl);
                    modal.hide();
                } else {
                    showToast('Lỗi khi xóa', 'error');
                }
            } catch (err) {
                showToast('Lỗi khi xóa: ' + err.message, 'error');
            }
        });
    });
</script>