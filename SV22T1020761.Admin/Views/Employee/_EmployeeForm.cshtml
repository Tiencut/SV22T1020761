@{
    Layout = null;
}
@model SV22T1020761.Models.HR.Employee
<div class="modal-header">
    <h5 class="modal-title">@(Model.EmployeeID == 0 ? "Thêm nhân viên" : "Chỉnh sửa nhân viên")</h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
</div>
<div class="modal-body">
    <form id="formEmployee" method="post" enctype="multipart/form-data" action="~/Employee/SaveData">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="EmployeeID" />
        
        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert" style="display:none;"></div>

        <!-- Họ và tên -->
        <div class="mb-3">
            <label class="form-label">Họ và tên <span class="text-danger">*</span></label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-person-fill"></i></span>
                <input asp-for="FullName" class="form-control" placeholder="Nhập họ và tên" required />
            </div>
            <span asp-validation-for="FullName" class="text-danger small d-block mt-1"></span>
        </div>

        <!-- Email -->
        <div class="mb-3">
            <label class="form-label">Email</label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-envelope-fill"></i></span>
                <input asp-for="Email" type="email" class="form-control" placeholder="example@domain.com" />
            </div>
            <span asp-validation-for="Email" class="text-danger small d-block mt-1"></span>
        </div>

        <!-- Ngày sinh -->
        <div class="mb-3">
            <label class="form-label">Ngày sinh</label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-calendar-event-fill"></i></span>
                <input asp-for="BirthDate" type="date" class="form-control" />
            </div>
            <span asp-validation-for="BirthDate" class="text-danger small d-block mt-1"></span>
        </div>

        <!-- Điện thoại -->
        <div class="mb-3">
            <label class="form-label">Điện thoại</label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-telephone-fill"></i></span>
                <input asp-for="Phone" type="tel" class="form-control" placeholder="0123456789" />
            </div>
            <span asp-validation-for="Phone" class="text-danger small d-block mt-1"></span>
        </div>

        <!-- Địa chỉ -->
        <div class="mb-3">
            <label class="form-label">Địa chỉ</label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-geo-alt-fill"></i></span>
                <textarea asp-for="Address" class="form-control" placeholder="Nhập địa chỉ" rows="2"></textarea>
            </div>
            <span asp-validation-for="Address" class="text-danger small d-block mt-1"></span>
        </div>

        <!-- Ảnh đại diện -->
        <div class="mb-3">
            <label class="form-label">Ảnh đại diện</label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-image-fill"></i></span>
                <input type="file" name="uploadPhoto" class="form-control" accept="image/*" />
            </div>
            @if (!string.IsNullOrEmpty(Model.Photo))
            {
                <div class="mt-2">
                    <small class="text-muted">Ảnh hiện tại:</small>
                    <br />
                    <img src="~/images/employees/@Model.Photo" class="img-thumbnail mt-2" style="max-height:120px; max-width:150px;" alt="Employee Photo" />
                </div>
            }
        </div>

        <!-- Trạng thái làm việc -->
        <div class="mb-3">
            <div class="form-check form-switch">
                <input type="hidden" name="IsWorking" value="false" />
                <input type="checkbox" name="IsWorking" id="IsWorking" class="form-check-input" value="true" @(Model.IsWorking == true ? "checked" : "") />
                <label class="form-check-label" for="IsWorking">
                    <strong>Đang làm việc</strong>
                </label>
            </div>
        </div>
    </form>
</div>
<div class="modal-footer">
    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
        <i class="bi bi-x-circle"></i> Hủy
    </button>
    <button type="submit" form="formEmployee" class="btn btn-primary">
        <i class="bi bi-save"></i> Lưu
    </button>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var form = document.getElementById('formEmployee');
        form.addEventListener('submit', async function (e) {
            e.preventDefault();
            if (!$(form).valid()) return;
            var url = form.action;
            var formData = new FormData(form);
            try {
                var res = await fetch(url, {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    body: formData
                });
                if (res.ok) {
                    var html = await res.text();
                    document.getElementById('employeeTableContainer').innerHTML = html;
                    var modalEl = document.getElementById('dialogModal');
                    var modal = bootstrap.Modal.getInstance(modalEl) || new bootstrap.Modal(modalEl);
                    modal.hide();
                } else {
                    var html = await res.text();
                    document.querySelector('#dialogModal .modal-content').innerHTML = html;
                }
            } catch (err) {
                showToast('Lỗi khi Lưu: ' + err.message, 'error');
            }
        });
    });
</script>