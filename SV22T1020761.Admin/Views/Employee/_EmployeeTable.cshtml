@model PagedResult<SV22T1020761.Models.HR.Employee>

<table class="table table-bordered table-hover mb-0">
    <thead class="table-secondary">
        <tr>
            <th>Tên nhân viên</th>
            <th>Ngày sinh</th>
            <th>Điện thoại</th>
            <th>Email</th>
            <th>Địa chỉ</th>
            <th class="text-center" style="width:120px;">Trạng thái</th>
            <th class="text-center" style="width:100px;">Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @if (Model?.DataItems != null && Model.DataItems.Count > 0)
        {
            foreach (var item in Model.DataItems)
            {
                <tr>
                    <td>@item.FullName</td>
                    <td>@item.BirthDate?.ToString("dd/MM/yyyy")</td>
                    <td>@item.Phone</td>
                    <td>@item.Email</td>
                    <td>@item.Address</td>
                    <td class="text-center">
                        @if (item.IsWorking ?? false)
                        {
                            <span class="badge bg-success">Đang làm</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Nghỉ việc</span>
                        }
                    </td>
                    <td class="text-center text-nowrap">
                        <a href="#" class="btn btn-sm btn-primary open-employee-modal" data-url="@Url.Action("Form","Employee", new { id = item.EmployeeID })">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <a href="#" class="btn btn-sm btn-danger open-employee-modal" data-url="@Url.Action("Form","Employee", new { id = item.EmployeeID })?delete=true">
                            <i class="bi bi-trash"></i>
                        </a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="7" class="text-center">Không có dữ liệu</td>
            </tr>
        }
    </tbody>
</table>

<ul class="pagination justify-content-center mt-3">
    @if (Model != null && Model.PageCount > 1)
    {
        if (Model.Page > 1)
        {
            <li class="page-item">
                <a class="page-link" href="#" data-page="1">&laquo;</a>
            </li>
        }
        for (int i = Math.Max(1, Model.Page - 2); i <= Math.Min(Model.PageCount, Model.Page + 2); i++)
        {
            <li class="page-item @(i == Model.Page ? "active" : "")">
                <a class="page-link" href="#" data-page="@i">@i</a>
            </li>
        }
        if (Model.Page < Model.PageCount)
        {
            <li class="page-item">
                <a class="page-link" href="#" data-page="@Model.PageCount">&raquo;</a>
            </li>
        }
    }
</ul>