@model SV22T1020761.Models.Sales.Order
@{
    ViewBag.Title = "Thêm mới Đơn hàng";
}
<h2>Thêm mới Đơn hàng</h2>
<form asp-action="Create" method="post">
    <div class="form-group">
        <label for="CustomerName">Khách hàng</label>
        <input asp-for="CustomerName" class="form-control" />
        <span asp-validation-for="CustomerName" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label for="OrderDate">Ngày đặt</label>
        <input asp-for="OrderDate" class="form-control" />
        <span asp-validation-for="OrderDate" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label for="TotalAmount">Tổng tiền</label>
        <input asp-for="TotalAmount" class="form-control" />
        <span asp-validation-for="TotalAmount" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Lưu</button>
    <a asp-action="Index" class="btn btn-secondary">Hủy</a>
</form>

<div class="row">
    <!-- Tìm kiếm & chọn mặt hàng -->
    <div class="col-4">
        <div class="card card-outline card-primary h-100">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-search"></i>
                    Lựa chọn hàng cần bán
                </h5>
            </div>

            <div class="card-body">
                <!-- Search -->
                <form id="searchForm" class="mb-3">
                    <div class="input-group">
                        <input class="form-control"
                               id="searchValue"
                               name="searchValue"
                               placeholder="Nhập tên mặt hàng cần tìm" autofocus />
                        <button type="button" class="btn btn-primary" id="searchBtn">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </form>

                <!-- Danh sách mặt hàng -->
                <div id="productListContainer">
                    <div class="text-center text-muted py-5">
                        <i class="bi bi-inbox"></i>
                        <p>Nhập tên sản phẩm và bấm tìm kiếm</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Giỏ hàng và thông tin khách hàng -->
    <div class="col-8">
        <!-- Giỏ hàng -->
        <div class="row">
            <div class="col-12">
                <div class="card card-outline card-success">
                    <div class="card-header">
                        <h5 class="mb-0">
                            <i class="bi bi-cart"></i>
                            Danh sách mặt hàng đã chọn
                        </h5>
                    </div>

                    <div class="card-body">
                        <table class="table table-bordered table-hover align-middle">
                            <thead class="table-success">
                                <tr>
                                    <th class="text-center">#</th>
                                    <th style="width:auto">Tên hàng</th>
                                    <th class="text-center" style="width:100px">ĐVT</th>
                                    <th class="text-center" style="width:100px">SL</th>
                                    <th class="text-end" style="width:150px">Giá</th>
                                    <th class="text-end" style="width:150px">Thành tiền</th>
                                    <th style="width:80px"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    int itemIndex = 1;
                                    decimal totalAmount = 0;
                                    if (ViewBag.Cart != null && ViewBag.Cart.Count > 0)
                                    {
                                        foreach (var item in ViewBag.Cart)
                                        {
                                            decimal itemTotal = item.Quantity * item.SalePrice;
                                            totalAmount += itemTotal;
                                        }
                                    }
                                }
                                @if (ViewBag.Cart != null && ViewBag.Cart.Count > 0)
                                {
                                    foreach (var item in ViewBag.Cart)
                                    {
                                        <tr>
                                            <td class="text-center">@itemIndex</td>
                                            <td>@item.ProductName</td>
                                            <td class="text-center">@item.Unit</td>
                                            <td class="text-center">@item.Quantity</td>
                                            <td class="text-end">@item.SalePrice.ToString("N0")</td>
                                            <td class="text-end">@(item.Quantity * item.SalePrice).ToString("N0")</td>
                                            <td class="text-end text-nowrap">
                                                <a class="btn btn-sm btn-primary open-modal" href="~/Order/EditCartItem?productId=@item.ProductID" title="Sửa">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                                <a class="btn btn-sm btn-danger open-modal" href="~/Order/DeleteCartItem?productId=@item.ProductID" title="Xóa">
                                                    <i class="bi bi-dash"></i>
                                                </a>
                                            </td>
                                        </tr>
                                        itemIndex++;
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="7" class="text-center text-muted py-3">
                                            Chưa có mặt hàng nào được chọn
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr>
                                    <th colspan="5" class="text-end">Tổng cộng:</th>
                                    <th class="text-end">@totalAmount.ToString("N0")</th>
                                    <th></th>
                                </tr>
                            </tfoot>
                        </table>

                        <div class="text-end">
                            <a class="btn btn-sm btn-danger mt-2 open-modal"                               
                               href="~/Order/ClearCart">
                                <i class="bi bi-trash"></i>
                                Xóa giỏ hàng
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Thông tin khách hàng và nơi giao hàng -->
        <div class="row mt-3">
            <div class="col-12">
                <div class="card card-outline card-info">
                    <div class="card-header">
                        <h5 class="mb-0">
                            <i class="bi bi-person"></i>
                            Thông tin khách hàng & nơi giao hàng
                        </h5>
                    </div>

                    <div class="card-body">
                        @if (TempData["Error"] != null)
                        {
                            <div class="alert alert-danger">
                                @TempData["Error"]
                            </div>
                        }
                        <form method="post">
                            <div class="row mb-3">
                                <label class="col-md-2 col-form-label">Khách hàng</label>
                                <div class="col-md-10">
                                    <select class="form-select" name="CustomerID" asp-items="@(ViewBag.Customers as SelectList)">
                                        <option value="">-- Chọn khách hàng --</option>
                                    </select>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <label class="col-md-2 col-form-label">Tỉnh/thành</label>
                                <div class="col-md-10">
                                    <select class="form-select" name="DeliveryProvince" asp-items="@(ViewBag.Provinces as SelectList)">
                                        <option value="">-- Chọn Tỉnh/thành giao hàng --</option>
                                    </select>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <label class="col-md-2 col-form-label">Địa chỉ</label>
                                <div class="col-md-10">
                                    <textarea class="form-control"></textarea>
                                </div>
                            </div>

                            <div class="text-end">
                                <button class="btn btn-primary">
                                    <i class="bi bi-check-circle"></i>
                                    Lập đơn hàng
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Search products via AJAX
    function searchProducts(page = 1) {
        const searchValue = document.getElementById('searchValue').value;
        
        fetch(`@Url.Action("SearchProducts", "Order")?searchValue=${encodeURIComponent(searchValue)}&page=${page}&pageSize=10`)
            .then(response => response.text())
            .then(html => {
                document.getElementById('productListContainer').innerHTML = html;
                // Re-attach event listeners to new buttons
                attachAddToCartListeners();
            })
            .catch(error => {
                console.error('Error:', error);
                document.getElementById('productListContainer').innerHTML = `<div class="alert alert-danger">Lỗi tải dữ liệu: ${error.message}</div>`;
            });
    }

    function attachAddToCartListeners() {
        document.querySelectorAll('.add-to-cart').forEach(btn => {
            btn.removeEventListener('click', handleAddToCart);
            btn.addEventListener('click', handleAddToCart);
        });
    }

    function handleAddToCart(e) {
        e.preventDefault();
        
        const productID = this.dataset.productId;
        const quantity = parseInt(this.parentElement.querySelector('input[name="quantity"]').value);
        
        // Call AJAX to add to cart
        fetch('@Url.Action("AddToCart", "Order")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({
                productID: productID,
                quantity: quantity
            })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                alert(data.message);
                // Reload cart and refresh page
                location.reload();
            } else {
                alert('Lỗi: ' + data.message);
            }
        })
        .catch(error => console.error('Error:', error));
    }

    // Load products on page load
    document.addEventListener('DOMContentLoaded', function() {
        // Handle search button click
        const searchBtn = document.getElementById('searchBtn');
        if (searchBtn) {
            searchBtn.addEventListener('click', function(e) {
                e.preventDefault();
                searchProducts(1);
            });
        }

        // Handle Enter key in search input
        const searchValue = document.getElementById('searchValue');
        if (searchValue) {
            searchValue.addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    searchProducts(1);
                }
            });
        }
    });
</script>
