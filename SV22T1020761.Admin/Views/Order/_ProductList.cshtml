@model PagedResult<SV22T1020761.Models.Catalog.Product>

@{
    int itemIndex = 1;
}

@if (Model?.DataItems != null && Model.DataItems.Count > 0)
{
    @foreach (var product in Model.DataItems)
    {
        <form method="post" class="border rounded p-2 mb-2">
            <strong>@product.ProductName</strong>

            <div class="row mt-2">
                <div class="col-4">
                    <img src="@(string.IsNullOrEmpty(product.Photo) ? "~/images/products/demo.png" : $"~/images/products/{product.Photo}")"
                         class="img-fluid border" style="max-height:100px" onerror="this.src='/images/products/demo.png'" />
                </div>
                <div class="col-8">
                    <div class="row g-2">
                        <div class="col-7">
                            <label class="form-label mb-0">Giá</label>
                            <input type="hidden" name="productID" value="@product.ProductID" />
                            <input class="form-control form-control-sm money-input"
                                   value="@product.Price.ToString("N0")"
                                   readonly />
                        </div>
                        <div class="col-5">
                            <label class="form-label mb-0">SL</label>
                            <input type="number"
                                   name="quantity"
                                   min="1"
                                   value="1"
                                   class="form-control form-control-sm" />
                        </div>
                    </div>

                    <button type="button" class="btn btn-sm btn-primary mt-2 w-100 add-to-cart"
                            data-product-id="@product.ProductID"
                            data-product-name="@product.ProductName"
                            data-product-price="@product.Price"
                            data-product-unit="@product.Unit"
                            data-product-photo="@(string.IsNullOrEmpty(product.Photo) ? "demo.png" : product.Photo)">
                        <i class="bi bi-cart-plus"></i>
                        Thêm vào giỏ
                    </button>
                </div>
            </div>
        </form>
        itemIndex++;
    }
}
else
{
    <div class="alert alert-info" role="alert">
        Không tìm thấy sản phẩm nào
    </div>
}

@* Pagination *@
@if (Model != null && Model.PageCount > 1)
{
    <div class="card-footer">
        <ul class="pagination justify-content-between mb-0">
            <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                <a class="page-link search-page-link" href="#" data-page="@(Model.Page - 1)">
                    <i class="bi bi-chevron-left"></i>
                </a>
            </li>
            <li class="page-item">
                <small class="form-text">Trang @Model.Page / @Model.PageCount</small>
            </li>
            <li class="page-item @(Model.Page >= Model.PageCount ? "disabled" : "")">
                <a class="page-link search-page-link" href="#" data-page="@(Model.Page + 1)">
                    <i class="bi bi-chevron-right"></i>
                </a>
            </li>
        </ul>
    </div>
}

<script>
    // Handle Add to Cart
    document.querySelectorAll('.add-to-cart').forEach(btn => {
        btn.addEventListener('click', function(e) {
            e.preventDefault();
            
            const productID = this.dataset.productId;
            const quantity = parseInt(this.parentElement.querySelector('input[name="quantity"]').value);
            
            // Call AJAX to add to cart
            fetch('@Url.Action("AddToCart", "Order")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    productID: productID,
                    quantity: quantity
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert(data.message);
                    // Reload cart
                    location.reload();
                } else {
                    alert('Lỗi: ' + data.message);
                }
            })
            .catch(error => console.error('Error:', error));
        });
    });

    // Handle Pagination
    document.querySelectorAll('.search-page-link').forEach(link => {
        link.addEventListener('click', function(e) {
            e.preventDefault();
            const page = this.dataset.page;
            searchProducts(page);
        });
    });
</script>
