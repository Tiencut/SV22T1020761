@using SV22T1020761.Admin.AppCodes

@{
    var userData = User.GetUserData();
    var displayName = userData?.DisplayName ?? "Người dùng";
    var userPhoto = userData?.Photo ?? "user-default.png";
}

<nav class="app-header navbar navbar-expand bg-body-secondary">
    <div class="container-fluid">
        <ul class="navbar-nav">
            <li class="nav-item">
                <a class="nav-link" data-lte-toggle="sidebar" href="#" role="button">
                    <i class="bi bi-list"></i>
                </a>
            </li>
            <li class="nav-item d-none d-md-block"><a href="~/" class="nav-link">Trang chủ</a></li>            
        </ul>        
        <ul class="navbar-nav ms-auto">            
            <li class="nav-item dropdown user-menu">
                <a href="#" class="nav-link dropdown-toggle" data-bs-toggle="dropdown">
                    <img src="~/lib/adminlte/assets/img/user2-160x160.jpg" class="user-image rounded-circle shadow" alt="User Image" />
                    <span class="d-none d-md-inline">@displayName</span>
                </a>
                <ul class="dropdown-menu dropdown-menu-lg dropdown-menu-end">                    
                    <li class="user-header text-bg-primary">
                        <img src="~/lib/adminlte/assets/img/user2-160x160.jpg" class="rounded-circle shadow" alt="User Image" />
                        <p>
                            @displayName
                            <small>@(userData?.UserName ?? "Không xác định")</small>
                        </p>
                    </li>                    
                    <li class="user-footer">
                        <a href="~/Account/ChangePassword" class="btn btn-default btn-flat">Đổi mật khẩu</a>
                        <form method="post" action="~/Account/LogoutPost" style="display: inline;">
                            <button type="submit" class="btn btn-default btn-flat float-end" style="border: none; background: none; cursor: pointer;">Thoát</button>
                        </form>
                    </li>                    
                </ul>
            </li>            
        </ul>        
    </div>
</nav>