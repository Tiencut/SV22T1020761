@{
    Layout = null;
}
@model SV22T1020761.Models.Partner.Shipper

<div class="modal-header">
    <h5 class="modal-title">@(Model?.ShipperID > 0 ? "Chỉnh sửa người giao hàng" : "Thêm mới người giao hàng")</h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
</div>

<form id="formShipper" method="post" action="@(Model?.ShipperID > 0 ? Url.Action("Edit", "Shipper") : Url.Action("Create", "Shipper"))">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="ShipperID" />
    
    <div class="modal-body">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
        
        <div class="mb-3">
            <label class="form-label">Tên người giao hàng <span class="text-danger">*</span></label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-truck"></i></span>
                <input asp-for="ShipperName" class="form-control" placeholder="Nhập tên người giao hàng" required />
            </div>
            <span asp-validation-for="ShipperName" class="text-danger small d-block mt-1"></span>
        </div>
        
        <div class="mb-3">
            <label class="form-label">Số điện thoại</label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-telephone-fill"></i></span>
                <input asp-for="Phone" type="tel" class="form-control" placeholder="0123456789" />
            </div>
            <span asp-validation-for="Phone" class="text-danger small d-block mt-1"></span>
        </div>
    </div>
    
    <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
            <i class="bi bi-x-circle"></i> Hủy
        </button>
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-save"></i> Lưu
        </button>
    </div>
</form>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        var form = document.getElementById('formShipper');
        form.addEventListener('submit', async function (e) {
            e.preventDefault();
            if (!$(form).valid()) return;
            var url = form.action;
            var formData = new FormData(form);
            try {
                var res = await fetch(url, {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    body: formData
                });
                if (res.ok) {
                    var html = await res.text();
                    document.getElementById('shipperTableContainer').innerHTML = html;
                    var modalEl = document.getElementById('dialogModal');
                    var modal = bootstrap.Modal.getInstance(modalEl) || new bootstrap.Modal(modalEl);
                    modal.hide();
                } else {
                    var html = await res.text();
                    document.querySelector('#dialogModal .modal-content').innerHTML = html;
                }
            } catch (err) {
                showToast('L?i khi Lưu: ' + err.message, 'error');
            }
        });
    });
</script>