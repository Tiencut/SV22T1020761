@{
    Layout = null;
}
@model SV22T1020761.Models.Partner.Supplier

<div class="modal-header">
    <h5 class="modal-title">@(Model?.SupplierID > 0 ? "Chỉnh sửa nhà cung cấp" : "Thêm mới nhà cung cấp")</h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
</div>

<form id="formSupplier" method="post" action="@(Model?.SupplierID > 0 ? Url.Action("Edit", "Supplier") : Url.Action("Create", "Supplier"))">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="SupplierID" />
    
    <div class="modal-body">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
        
        <div class="mb-3">
            <label class="form-label">Tên nhà cung cấp <span class="text-danger">*</span></label>
            <input asp-for="SupplierName" class="form-control" required />
            <span asp-validation-for="SupplierName" class="text-danger small"></span>
        </div>
        
        <div class="mb-3">
            <label class="form-label">Liên hệ <span class="text-danger">*</span></label>
            <input asp-for="ContactName" class="form-control" required />
            <span asp-validation-for="ContactName" class="text-danger small"></span>
        </div>
        
        <div class="mb-3">
            <label class="form-label">Địa chỉ</label>
            <input asp-for="Address" class="form-control" />
            <span asp-validation-for="Address" class="text-danger small"></span>
        </div>
    </div>
    
    <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
        <button type="submit" class="btn btn-primary">Lưu</button>
    </div>
</form>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        var form = document.getElementById('formSupplier');
        form.addEventListener('submit', async function (e) {
            e.preventDefault();
            if (!$(form).valid()) return;
            var url = form.action;
            var formData = new FormData(form);
            try {
                var res = await fetch(url, {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    body: formData
                });
                if (res.ok) {
                    var html = await res.text();
                    document.getElementById('supplierTableContainer').innerHTML = html;
                    var modalEl = document.getElementById('dialogModal');
                    var modal = bootstrap.Modal.getInstance(modalEl) || new bootstrap.Modal(modalEl);
                    modal.hide();
                } else {
                    var html = await res.text();
                    document.querySelector('#dialogModal .modal-content').innerHTML = html;
                }
            } catch (err) {
                showToast('L?i khi Lưu: ' + err.message, 'error');
            }
        });
    });
</script>