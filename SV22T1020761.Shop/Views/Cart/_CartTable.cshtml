@model System.Collections.Generic.List<SV22T1020761.Shop.AppCodes.CartItem>
@using System.Linq
<table class="table">
    <thead>
        <tr>
            <th style="width:80px;">Ảnh</th>
            <th>Sản phẩm</th>
            <th>Số lượng</th>
            <th>Giá</th>
            <th>Thành tiền</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach(var item in Model)
        {
            <tr>
                <td>
                    <img src="~/admin-images/products/@item.Photo" style="width:80px;height:80px;object-fit:cover;" 
                         onerror="this.onerror=null;this.src='~/admin-images/products/nophoto.png'" />
                </td>
                <td>@item.ProductName</td>
                <td>
                    <form class="d-inline" method="post" asp-controller="Cart" asp-action="Update">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="productId" value="@item.ProductID" />
                        <input type="number" name="qty" value="@item.Qty" min="1" style="width:80px;" />
                        <button class="btn btn-sm btn-primary">Cập nhật</button>
                    </form>
                </td>
                <td>@item.Price.ToString("N0") đ</td>
                <td>@{var itemTotal = item.Price * item.Qty;}<span>@itemTotal.ToString("N0") đ</span></td>
                <td>
                    <form method="post" asp-controller="Cart" asp-action="Remove">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="productId" value="@item.ProductID" />
                        <button class="btn btn-sm btn-danger">Xoá</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

@{
    var total = Model.Sum(i => i.Price * i.Qty);
}
<div class="d-flex justify-content-between align-items-center border-top pt-3">
    <div>
        <div class="h5 mb-0">Tổng: <strong class="text-primary">@total.ToString("N0") đ</strong></div>
        <div class="text-muted small">(Chưa bao gồm phí vận chuyển)</div>
    </div>
    <div>
        <a class="btn btn-success btn-lg" asp-controller="Checkout" asp-action="Index">Đặt mua hàng</a>
    </div>
</div>
