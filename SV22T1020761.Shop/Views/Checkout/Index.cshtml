@{
    ViewData["Title"] = "Thanh toán";
}

<h3>Thanh toán</h3>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row">
    <div class="col-md-6">
        <form asp-action="Place" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
            <div class="mb-3">
                <label class="form-label">Tỉnh/Thành</label>
                <select name="deliveryProvince" class="form-select" required>
                    @{
                        var provinces = ViewBag.Provinces as System.Collections.Generic.List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>;
                        var defaultProvince = ViewBag.CustomerProvince as string;
                    }
                    @if (!string.IsNullOrWhiteSpace(defaultProvince))
                    {
                        <option value="@defaultProvince" selected>@defaultProvince</option>
                    }
                    @if (provinces != null)
                    {
                        @foreach(var p in provinces)
                        {
                            @if (p.Value != defaultProvince)
                            {
                                <option value="@p.Value">@p.Text</option>
                            }
                        }
                    }
                </select>
                <span class="form-help">Chọn tỉnh/thành để tính phí vận chuyển.</span>
            </div>
            <div class="mb-3">
                <label class="form-label">Địa chỉ</label>
                <input name="deliveryAddress" class="form-control" placeholder="Số nhà, đường, phường/quận" value="@(ViewBag.CustomerAddress as string ?? "")" required />
            </div>
            <button class="btn btn-success">Đặt hàng</button>
        </form>
    </div>
    <div class="col-md-6">
        <h5>Tóm tắt giỏ hàng</h5>
        <div id="checkoutCart">
            @{
                var summary = ViewBag.Summary as (int Count, decimal Total)?;
                var cart = ViewBag.Cart as System.Collections.Generic.List<SV22T1020761.Shop.AppCodes.CartItem>;
            }
            @if (cart != null && cart.Count>0)
            {
                <table class="table">
                    <thead><tr><th>Sản phẩm</th><th>Số lượng</th><th>Giá</th><th>Thành tiền</th></tr></thead>
                    <tbody>
                        @foreach(var it in cart)
                        {
                            <tr>
                                <td>@it.ProductName</td>
                                <td>@it.Qty</td>
                                <td>@it.Price.ToString("N0") đ</td>
                                <td>@String.Format("{0:N0}", it.Price * it.Qty) đ</td>
                            </tr>
                        }
                    </tbody>
                </table>
                <p class="h5">Tổng: <strong>@summary?.Total.ToString("N0") đ</strong></p>
            }
            else
            {
                <div class="alert alert-warning">Giỏ hàng trống</div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var form = document.querySelector('form[asp-action="Place"]');
            form?.addEventListener('submit', function (e) {
                var province = document.querySelector('select[name="deliveryProvince"]').value;
                var address = document.querySelector('input[name="deliveryAddress"]').value;
                
                if (!province || province.trim() === '') {
                    e.preventDefault();
                    alert('Vui lòng chọn Tỉnh/Thành phố');
                    return false;
                }
                
                if (!address || address.trim() === '') {
                    e.preventDefault();
                    alert('Vui lòng nhập địa chỉ giao hàng');
                    return false;
                }
            });
        });
    </script>
}
