@model SV22T1020761.Models.Common.PagedResult<SV22T1020761.Models.Catalog.Product>
@{
    ViewData["Title"] = "Danh sách sản phẩm";
}
<div class="container">
    <h3>@ViewData["Title"]</h3>
    <form id="formSearch" method="post" asp-action="Search" asp-controller="Products">
        @Html.AntiForgeryToken()
        <div class="row mb-3 g-3">
            <div class="col-lg-5 col-md-4 col-sm-12">
                <input type="text" name="SearchValue" value="@ViewBag.FilterSearchValue"
                       class="form-control form-control-lg"
                       placeholder="Tìm kiếm sản phẩm..."
                       autofocus />
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <select name="CategoryID" class="form-select form-select-lg">
                    <option value="0">-- Tất cả loại --</option>
                    @foreach (var c in (System.Collections.Generic.List<SV22T1020761.Models.Catalog.Category>)(ViewBag.Categories ?? new System.Collections.Generic.List<SV22T1020761.Models.Catalog.Category>()))
                    {
                        if (ViewBag.FilterCategoryId == c.CategoryID)
                        {
                            <option value="@c.CategoryID" selected>@c.CategoryName</option>
                        }
                        else
                        {
                            <option value="@c.CategoryID">@c.CategoryName</option>
                        }
                    }
                </select>
            </div>
            <div class="col-lg-2 col-md-2 col-sm-3">
                <input type="number" name="MinPrice" step="0.01"
                       placeholder="Min"
                       value="@ViewBag.FilterMinPrice"
                       class="form-control form-control-lg" />
            </div>
            <div class="col-lg-1 col-md-1 col-sm-3">
                <input type="number" name="MaxPrice" step="0.01"
                       placeholder="Max"
                       value="@ViewBag.FilterMaxPrice"
                       class="form-control form-control-lg" />
            </div>
            <div class="col-lg-1 col-md-1 col-sm-12">
                <button type="button" id="searchBtn" class="btn btn-primary btn-lg w-100 h-100">Tìm</button>
            </div>
        </div>
    </form>

    <div id="productTableContainer">
        @Html.Partial("../Shared/_ProductGrid", Model)
    </div>
</div>

<!-- Modal for quick view -->
<div class="modal fade" id="dialogModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content"></div>
    </div>
</div>

@section Scripts {
    <script>
        var form = document.getElementById('formSearch');
        
        function debounce(fn, delay) {
            var t;
            return function () {
                clearTimeout(t);
                t = setTimeout(fn, delay);
            };
        }

        // Make doSearch global
        window.doSearch = async function(page) {
            var data = new URLSearchParams(new FormData(form));
            if (page) data.set('Page', page);
            
            var url = '/Products/Search';
            
            try {
                var res = await fetch(url, {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: data.toString()
                });
                
                if (res.ok) {
                    var html = await res.text();
                    document.getElementById('productTableContainer').innerHTML = html;
                } else {
                    console.error('Search failed');
                }
            } catch (err) {
                console.error('Error:', err);
            }
        };

        if (form) {
            var input = form.querySelector('input[name="SearchValue"]');
            var searchBtn = document.getElementById('searchBtn');
            
            if (input) {
                var debounced = debounce(function () { doSearch(1); }, 300);
                input.addEventListener('keyup', debounced);
            }

            if (searchBtn) {
                searchBtn.addEventListener('click', function () {
                    doSearch(1);
                });
            }
        }
    </script>
}